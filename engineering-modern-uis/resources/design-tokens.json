{
    "$schema": "https://design-tokens.github.io/community-group/format/",
    "meta": {
        "name": "diseño-UI/UX — 2026 Design Tokens",
        "version": "1.0.0",
        "colorSpace": "oklch"
    },
    "color": {
        "primary": {
            "base": "oklch(65% 0.25 260)",
            "dim": "oklch(55% 0.20 260)",
            "bright": "oklch(75% 0.28 260)",
            "subtle": "oklch(92% 0.06 260)"
        },
        "accent": {
            "base": "oklch(75% 0.18 160)",
            "dim": "oklch(60% 0.15 160)",
            "bright": "oklch(85% 0.20 160)",
            "subtle": "oklch(94% 0.05 160)"
        },
        "danger": {
            "base": "oklch(60% 0.25 30)",
            "dim": "oklch(50% 0.20 30)",
            "bright": "oklch(70% 0.28 30)",
            "subtle": "oklch(93% 0.06 30)"
        },
        "warning": {
            "base": "oklch(75% 0.18 85)",
            "dim": "oklch(60% 0.15 85)",
            "bright": "oklch(85% 0.22 85)",
            "subtle": "oklch(95% 0.05 85)"
        },
        "success": {
            "base": "oklch(65% 0.20 150)",
            "dim": "oklch(50% 0.16 150)",
            "bright": "oklch(78% 0.22 150)",
            "subtle": "oklch(93% 0.05 150)"
        },
        "neutral": {
            "light": {
                "surface": "oklch(98% 0.005 260)",
                "surfaceAlt": "oklch(95% 0.008 260)",
                "border": "oklch(88% 0.010 260)",
                "text": "oklch(20% 0.020 260)",
                "textMuted": "oklch(45% 0.020 260)"
            },
            "dark": {
                "surface": "oklch(15% 0.010 260)",
                "surfaceAlt": "oklch(20% 0.012 260)",
                "border": "oklch(30% 0.015 260)",
                "text": "oklch(90% 0.010 260)",
                "textMuted": "oklch(65% 0.010 260)"
            }
        }
    },
    "spacing": {
        "2xs": "clamp(0.125rem, 0.25vw, 0.25rem)",
        "xs": "clamp(0.25rem,  0.5vw,  0.5rem)",
        "sm": "clamp(0.5rem,   1vw,    0.75rem)",
        "md": "clamp(0.75rem,  1.5vw,  1.25rem)",
        "lg": "clamp(1.25rem,  2.5vw,  2rem)",
        "xl": "clamp(2rem,     4vw,    3.5rem)",
        "2xl": "clamp(3rem,     6vw,    5rem)"
    },
    "typography": {
        "fontFamily": {
            "sans": "'Inter', system-ui, -apple-system, sans-serif",
            "mono": "'JetBrains Mono', 'Fira Code', monospace"
        },
        "fontSize": {
            "xs": "clamp(0.75rem,   0.3vw + 0.7rem,   0.8125rem)",
            "sm": "clamp(0.8125rem, 0.4vw + 0.75rem,  0.9375rem)",
            "base": "clamp(1rem,      0.5vw + 0.875rem, 1.125rem)",
            "lg": "clamp(1.25rem,   0.8vw + 1rem,     1.5rem)",
            "xl": "clamp(1.5rem,    1.2vw + 1.125rem, 2rem)",
            "2xl": "clamp(2rem,      2vw + 1.5rem,     3rem)",
            "3xl": "clamp(2.5rem,    3vw + 2rem,       4rem)"
        },
        "lineHeight": {
            "tight": 1.1,
            "snug": 1.3,
            "normal": 1.6,
            "relaxed": 1.8
        },
        "fontWeight": {
            "normal": 400,
            "medium": 500,
            "semibold": 600,
            "bold": 700,
            "black": 800
        }
    },
    "radius": {
        "sm": "0.375rem",
        "md": "0.75rem",
        "lg": "1.25rem",
        "xl": "1.75rem",
        "full": "9999px"
    },
    "shadow": {
        "sm": "0 1px 2px oklch(0% 0 0 / 0.05)",
        "md": "0 4px 12px oklch(0% 0 0 / 0.08)",
        "lg": "0 8px 32px oklch(0% 0 0 / 0.12)",
        "xl": "0 16px 48px oklch(0% 0 0 / 0.16)"
    },
    "motion": {
        "easing": {
            "ease-out": "cubic-bezier(0.16, 1, 0.3, 1)",
            "ease-in-out": "cubic-bezier(0.65, 0, 0.35, 1)",
            "spring": "cubic-bezier(0.34, 1.56, 0.64, 1)"
        },
        "duration": {
            "instant": "75ms",
            "fast": "150ms",
            "normal": "250ms",
            "slow": "400ms",
            "glacial": "700ms"
        }
    },
    "breakpoints": {
        "sm": "30rem",
        "md": "48rem",
        "lg": "64rem",
        "xl": "80rem",
        "2xl": "96rem"
    },
    "performanceBudget": {
        "LCP": {
            "target": 1000,
            "limit": 1200,
            "unit": "ms"
        },
        "INP": {
            "target": 40,
            "limit": 50,
            "unit": "ms"
        },
        "CLS": {
            "target": 0.03,
            "limit": 0.05,
            "unit": "score"
        },
        "jsBundle": {
            "limit": 50,
            "unit": "KB"
        },
        "cssBundle": {
            "limit": 20,
            "unit": "KB"
        }
    }
}